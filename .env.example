APP_NAME=GroupTrade Bot
APP_HOST=127.0.0.1
APP_PORT=8080
DATABASE_URL=sqlite:///./grouptrade.db
WEB_BASE_URL=http://127.0.0.1:8080
TELEGRAM_MESSAGE_STORE_PATH=./telegram_messages.json

# Telegram source listener via Telethon
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_telethon_api_hash
TELEGRAM_SESSION_NAME=grouptrade_listener
TELEGRAM_SOURCE_CHAT_IDS=-1001234567890,-1009876543210

# Telegram control bot via BotFather
TELEGRAM_BOT_TOKEN=123456:telegram_bot_token
TELEGRAM_NOTIFY_CHAT_ID=123456789

# Bybit
BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret
BYBIT_TESTNET=true
BYBIT_CATEGORY=linear
BYBIT_ACCOUNT_TYPE=UNIFIED
BYBIT_RECV_WINDOW_MS=20000
BYBIT_TIMESTAMP_SAFETY_MS=5000
BYBIT_TIMESTAMP_SAFETY_STEP_MS=1000
BYBIT_TIMESTAMP_SAFETY_MAX_MS=15000
DEFAULT_QUOTE_ASSET=USDT
FIXED_MARGIN_USDT=25
MIN_LEVERAGE=1
MAX_LEVERAGE=25
TARGET_SL_LOSS_PCT=0.32
TP1_RATIO=0.5
TP2_RATIO=0.5

# AI decision engine
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
AI_AUTO_APPROVE=true
AI_MIN_CONFIDENCE=0.55
